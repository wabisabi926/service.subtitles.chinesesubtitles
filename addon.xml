<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="service.subtitles.chinesesubtitles" name="ChineseSub" version="1.0.0" provider-name="qzydustin">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.beautifulsoup4" version="4.12.2"/>
        <import addon="vfs.rar" version="21.0.2"/>
        <import addon="vfs.libarchive" version="21.0.2" optional="true"/>
        <import addon="script.module.requests" version="2.31.0"/>
    </requires>
    <extension point="xbmc.subtitle.module" library="resources/lib/addon_entry.py" />
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Chinese Subtitles</summary>
        <summary lang="zh_CN">中文字幕</summary>
        <description lang="en_GB">Search and download Chinese subtitles</description>
        <description lang="zh_CN">搜索并下载中文字幕</description>
        <platform>all</platform>
        <license>GPL-2.0-or-later</license>
        <assets>
            <icon>resources/icon.png</icon>
            <fanart>resources/fanart.jpeg</fanart>
        </assets>
    </extension>
</addon>
